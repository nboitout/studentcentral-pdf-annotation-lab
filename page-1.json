import json
from pathlib import Path

from app.models.benchmarks import BenchmarkDocument

BASE_DIR = Path(__file__).resolve().parent.parent
BENCHMARKS_DIR = BASE_DIR / "data" / "benchmarks"


def get_benchmark(doc_id: str) -> BenchmarkDocument:
    benchmark_path = BENCHMARKS_DIR / doc_id / "benchmark.json"
    if not benchmark_path.exists():
        raise FileNotFoundError(f"Benchmark not found: {doc_id}")

    with benchmark_path.open("r", encoding="utf-8") as file:
        data = json.load(file)

    return BenchmarkDocument(**data)
